# ── Required ───────────────────────────────────────────────────────────────────
BOT_TOKEN=your_telegram_bot_token_here
ADMIN_ID=your_telegram_user_id_here
DATABASE_URL=postgresql://user:password@host:5432/dbname

# ── Optional ───────────────────────────────────────────────────────────────────
# Secondary Telegram ID for notifications (defaults to ADMIN_ID if not set)
NOTIFY_ID=

# Your bot's username without @ (for referral links)
BOT_USERNAME=your_bot_username

# Your deployed URL (for keep-alive pings on Render free tier)
RENDER_URL=https://your-app.onrender.com
